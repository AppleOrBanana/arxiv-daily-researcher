{
  // ==================================================
  // Search Configuration
  // ==================================================
  "search_settings": {
    "search_days": 3,
    "max_results": 25,
    "max_results_per_source": {}
  },

  // ==================================================
  // Data Source Configuration
  // ==================================================
  "data_sources": {
    "enabled": [
      "arxiv",
      "openalex"
    ],
    "journals": [
      "be",
      "cea",
      "precision_agriculture",
      "smart_agricultural_technology",
      "jfr",
      "computers_in_industry",
      "journal_of_terramechanics",
      "applied_engineering_in_agriculture",
      "agriculture",
      "agronomy",
      "ijabe"
    ],
    "reports_by_source": false
  },
  // ==================================================
  // ArXiv Target Domain Configuration
  // ==================================================
  "target_domains": {
    "domains": [
      "cs.CV",
      "cs.RO",
      "cs.AI",
      "cs.LG",
      "eess.SY"
    ]
  },

  // ==================================================
  // Keyword Configuration
  // ==================================================
  "keywords": {
    "primary_keywords": {
      "weight": 1.0,
      "keywords": [
        "agricultural machinery",
        "smart agricultural machinery",
        "intelligent agricultural machinery",
        "agricultural robot",
        "field robot",
        "autonomous tractor",
        "autonomous agricultural vehicle",
        "precision agriculture",
        "agricultural automation",
        "orchard robot",
        "harvesting robot",
        "weeding robot",
        "computer vision",
        "crop detection",
        "fruit detection",
        "weed detection",
        "obstacle detection",
        "row detection",
        "semantic segmentation",
        "object detection",
        "visual navigation",
        "path planning",
        "trajectory tracking",
        "model predictive control",
        "MPC",
        "sensor fusion"
      ]
    },
    "enable_reference_extraction": false,
    "reference_keywords_config": {
      "max_keywords": 0,
      "similarity_threshold": 0.8,
      "weight_distribution": {
        "high_importance": {
          "weight": 1.0,
          "count": 0
        },
        "medium_importance": {
          "weight": 0.2,
          "count": 0
        },
        "low_importance": {
          "weight": 0.1,
          "count": 0
        }
      }
    },
    "research_context": "我关注智能化农机方向，研究链条是视觉做感知，算法做决策，控制做执行。优先筛选与农业机械、农业机器人、自动驾驶拖拉机、果园机器人、采收机器人、除草机器人、田间自主作业直接相关的工作。同时保留与农机视觉感知、果实/杂草/障碍物检测、作物行识别、语义分割、目标检测、视觉导航、路径规划、轨迹跟踪、模型预测控制、多传感器融合相关的方法论文。希望结果整体与农机领域强相关，但允许少量对农机有明显迁移价值的方法论文进入候选。"
  },

  // ==================================================
  // Scoring Configuration
  // ==================================================
  "scoring_settings": {
    "keyword_relevance_score": {
      "max_score_per_keyword": 10
    },
    "author_bonus": {
      "enabled": false,
      "expert_authors": [],
      "bonus_points": 5.0
    },
    "passing_score_formula": {
      "base_score": 6.0,
      "weight_coefficient": 2.6
    },
    "include_all_in_report": true
  },

  // ==================================================
  // Path Configuration
  // ==================================================
  "paths": {
    "data_dir": "data",
    "reference_pdfs": "data/reference_pdfs",
    "reports": "data/reports",
    "downloaded_pdfs": "data/downloaded_pdfs",
    "history_dir": "data/history"
  },

  // ==================================================
  // Keyword Trend Tracking Configuration
  // ==================================================
  "keyword_tracker": {
    "enabled": true,
    "database": {
      "path": "data/keywords/keywords.db"
    },
    "normalization": {
      "enabled": true,
      "batch_size": 25
    },
    "trend_view": {
      "default_days": 30
    },
    "charts": {
      "bar_chart": {
        "top_n": 15
      },
      "trend_chart": {
        "top_n": 5
      }
    },
    "report": {
      "enabled": true,
      "frequency": "weekly"
    }
  },

  // ==================================================
  // Notification Configuration
  // ==================================================
  "notifications": {
    "enabled": true,
    "on_success": true,
    "on_failure": true,
    "attach_reports": true,
    "top_n": 5,
    "channels": {
      "email": {
        "enabled": true
      },
      "wechat_work": {
        "enabled": false
      },
      "dingtalk": {
        "enabled": false
      },
      "telegram": {
        "enabled": false
      },
      "slack": {
        "enabled": false
      },
      "generic_webhook": {
        "enabled": false
      }
    }
  },

  // ==================================================
  // Retry Configuration
  // ==================================================
  "retry": {
    "max_attempts": 3,
    "min_wait": 2,
    "max_wait": 30
  },

  // ==================================================
  // Logging Configuration
  // ==================================================
  "logging": {
    "rotation_type": "time",
    "keep_days": 30
  },

  // ==================================================
  // Concurrency Configuration
  // ==================================================
  "concurrency": {
    "enabled": true,
    "workers": 2
  },

  // ==================================================
  // PDF Parser Configuration
  // ==================================================
  "pdf_parser": {
    "mode": "mineru",
    "mineru_model_version": "pipeline",
    "poll_interval": 3,
    "poll_timeout": 300
  },

  // ==================================================
  // Report Configuration
  // ==================================================
  "report_settings": {
    "enable_html_report": true
  },

  // ==================================================
  // Auto-update Configuration
  // ==================================================
  "auto_update": {
    "enabled": true
  },

  // ==================================================
  // Token Tracking Configuration
  // ==================================================
  "token_tracking": {
    "enabled": true
  },

  // ==================================================
  // Trend Research Mode Configuration
  // ==================================================
  "trend_research": {
    "default_date_range_days": 365,
    "max_results": 200,
    "sort_order": "ascending",
    "report_position": "end",
    "generate_tldr": true,
    "tldr_batch_size": 10,
    "output_formats": [
      "markdown",
      "html"
    ],
    "enabled_skills": [
      "comprehensive_analysis"
    ]
  }
}
